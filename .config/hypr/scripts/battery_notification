#!/bin/bash
# Battery low notification with weighted mean using watt-hours

notify_levels=(3 5 10 20)
last_notify=100

while true; do
    battery_count=0
    total_energy=0
    total_full=0
    charging_status_0=""
    charging_status_1=""

    # Battery 0
    if [ -d "/sys/class/power_supply/BAT0" ]; then
        energy_0=$(cat /sys/class/power_supply/BAT0/energy_now)
        full_0=$(cat /sys/class/power_supply/BAT0/energy_full)
        charging_status_0=$(cat /sys/class/power_supply/BAT0/status)
        total_energy=$((total_energy + energy_0))
        total_full=$((total_full + full_0))
        battery_count=$((battery_count + 1))
    fi

    # Battery 1
    if [ -d "/sys/class/power_supply/BAT1" ]; then
        energy_1=$(cat /sys/class/power_supply/BAT1/energy_now)
        full_1=$(cat /sys/class/power_supply/BAT1/energy_full)
        charging_status_1=$(cat /sys/class/power_supply/BAT1/status)
        total_energy=$((total_energy + energy_1))
        total_full=$((total_full + full_1))
        battery_count=$((battery_count + 1))
    fi

    # Calculate weighted mean battery level
    if [ $total_full -gt 0 ]; then
        bat_lvl=$(( total_energy * 100 / total_full ))
    else
        bat_lvl=0
    fi

    # Update last_notify if battery increased
    if [ $bat_lvl -gt $last_notify ]; then
        last_notify=$bat_lvl
    fi

    # Notify if not charging
    if [[ "$charging_status_0" != "Charging" ]] && [[ "$charging_status_1" != "Charging" ]]; then
        for notify_level in "${notify_levels[@]}"; do
            if [ $bat_lvl -le $notify_level ]; then
                if [ $notify_level -lt $last_notify ]; then
                    notify-send -u critical "Low Battery" "$bat_lvl% battery remaining."
                    last_notify=$bat_lvl
                fi
            fi
        done
    fi

    sleep 60
done
